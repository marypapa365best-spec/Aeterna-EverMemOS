# EverMemOS Cloud：在 https://console.evermind.ai/api-keys 创建 API Key，填到下面
EVERMEMOS_API_KEY=

# 可选：EverMemOS API 基地址（默认 https://api.evermind.ai）
# EVERMEMOS_API_BASE=https://api.evermind.ai

# 可选：后端服务端口（默认 3001）
# PORT=3001

# 分身对话（进化聊天室）：二选一或都填，优先使用 OpenAI
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=
